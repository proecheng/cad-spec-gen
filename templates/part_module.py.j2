def make_{{ func_name }}() -> cq.Workplane:
    """{{ part_no }}: {{ part_name_cn }} — {{ material }}

    Envelope: {{ envelope_w }} x {{ envelope_d }} x {{ envelope_h }} mm
    Weight: {{ weight }}g

    Axis: {{ principal_axis_desc | default('TODO — must match COORDINATE SYSTEM block above') }}
    Doc:  {{ axis_source_ref | default('TODO — cite design doc section + line') }}
    """
    # ── Geometry source: {{ source_ref }} ─────────────────────────────────────
    # Principal axis: {{ principal_axis_desc | default('TODO') }}
    # If this part needs a non-Z extrusion direction, document WHY here.
    #
    # NOTE: Approximate geometry from BOM dimensions / part-name heuristics.
    #       Refine with actual geometry citing design-doc lines.
{% if geom_type == "cylinder" %}
    body = cq.Workplane("XY").circle({{ geom_d }} / 2).extrude({{ geom_h }})
{% elif geom_type == "ring" %}
    body = (cq.Workplane("XY")
            .circle({{ geom_od }} / 2).extrude({{ geom_h }})
            .faces(">Z").workplane()
            .circle({{ geom_id }} / 2).cutThruAll())
{% elif geom_type == "disc_arms" %}
    _disc = cq.Workplane("XY").circle({{ geom_d }} / 2).extrude({{ geom_t }})
    _arm = cq.Workplane("XY").box({{ geom_arm_l }}, {{ geom_arm_w }}, {{ geom_t }},
                                  centered=(False, True, False))
    body = _disc
    for _angle in range(0, 360, {{ (360 // geom_arm_count) | int }}):
        body = body.union(_arm.rotate((0, 0, 0), (0, 0, 1), _angle))
{% elif geom_type == "l_bracket" %}
    _base = cq.Workplane("XY").box({{ geom_w }}, {{ geom_d }}, {{ geom_t }},
                                   centered=(True, True, False))
    _wall = (cq.Workplane("XY")
             .transformed(offset=(0, -{{ geom_d }} / 2 + {{ geom_t }} / 2, 0))
             .box({{ geom_w }}, {{ geom_t }}, {{ geom_h }},
                  centered=(True, True, False)))
    body = _base.union(_wall)
{% else %}
    body = cq.Workplane("XY").box(
        {{ envelope_w }}, {{ envelope_d }}, {{ envelope_h }},
        centered=(True, True, False))  # § refine with real geometry
{% endif %}
{% if has_mounting_holes %}

    # Mounting face bolt holes — per {{ mount_source_ref | default('TODO: cite doc line') }}
    from fasteners import cut_mounting_holes
    body = cut_mounting_holes(body, {{ mount_bolt_pcd }}, {{ mount_bolt_num }})
{% endif %}
{% if features %}

    # ── Auto-extracted features from §2/§3/§4/§8 ────────────────────────────
{% for feat in features %}
{% if feat.type == "through_hole" %}
    # {{ feat.source }} — {{ feat.count }}×Φ{{ feat.diameter }}
{% if feat.positions %}
    body = body.faces(">Z").workplane().pushPoints({{ feat.positions }}).hole({{ feat.diameter }})
{% else %}
    # TODO: fill hole positions from design doc, then uncomment:
    # body = body.faces(">Z").workplane().pushPoints([...]).hole({{ feat.diameter }})
{% endif %}
{% elif feat.type == "counterbore" %}
    # {{ feat.source }} — {{ feat.count }}×Φ{{ feat.diameter }} counterbore
    # TODO: fill positions + cbore dims from design doc
    # body = body.faces(">Z").workplane().pushPoints([...]).cboreHole({{ feat.diameter }}, cboreD, cboreDepth)
{% elif feat.type == "threaded_hole" %}
    # {{ feat.source }} — {{ feat.count }}×M{{ feat.diameter }} (tap drill Φ{{ feat.tap_drill_d }})
{% if feat.positions %}
    body = body.faces(">Z").workplane().pushPoints({{ feat.positions }}).hole({{ feat.tap_drill_d }})
{% else %}
    # TODO: fill hole positions from design doc, then uncomment:
    # body = body.faces(">Z").workplane().pushPoints([...]).hole({{ feat.tap_drill_d }})
{% endif %}
{% endif %}
{% endfor %}
{% endif %}

    return body


