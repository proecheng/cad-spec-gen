{
  "_doc": "CAD pipeline persistent config. Auto-detected on first run; edit manually to override.",
  "blender_path": "D:/Blender/blender.exe",
  "cadquery_python": "python",
  "output_base": "cad/output",
  "render": {
    "engine": "CYCLES",
    "samples": 512,
    "resolution": [1920, 1080],
    "denoiser": "OPENIMAGEDENOISE"
  },
  "timestamp": {
    "enabled": true,
    "format": "%Y%m%d_%H%M",
    "keep_latest_symlink": true
  },
  "archive": {
    "enabled": true,
    "max_versions": 10
  },
  "enhance": {
    "backend": "gemini",
    "_backend_doc": "Options: 'gemini' (cloud, soft geometry lock) | 'fal' (cloud, Flux ControlNet hard lock) | 'fal_comfy' (cloud, ComfyUI workflow on fal, hard lock) | 'comfyui' (local GPU, hard lock, free) | 'engineering' (no AI, Blender PBR direct, free). Leave empty for auto-detect.",
    "model": "nano_banana_pro",
    "temperature": 0.2,
    "seed_from_image": true,
    "reference_mode": "v1_anchor",
    "_consistency_doc": "reference_mode: 'v1_anchor' = use V1 enhanced result as style reference for V2+; 'none' = disabled. Run probe_proxy.py --write-config to auto-detect proxy capabilities.",
    "models": {
      "nano_banana": "gemini-2.5-flash-image",
      "nano_banana_pro": "gemini-3-pro-image-preview",
      "nano_banana_2": "gemini-3.1-flash-image",
      "nano_banana_4k": "gemini-3-pro-image-preview-4k"
    },
    "resolution": "2k",
    "timeout": 180,
    "comfyui": {
      "root": "D:/ComfyUI",
      "host": "127.0.0.1",
      "port": 8188,
      "workflow_template": "templates/comfyui_workflow_template.json",
      "checkpoint": "realisticVisionV60B1_v51VAE.safetensors",
      "controlnet_depth_model": "control_v11f1p_sd15_depth.pth",
      "controlnet_canny_model": "control_v11p_sd15_canny.pth",
      "denoise_strength": 0.45,
      "cfg_scale": 7.0,
      "steps": 25,
      "timeout": 7200
    },
    "fal": {
      "_doc": "fal.ai Flux ControlNet — cloud API, hard geometry lock. Requires FAL_KEY env var.",
      "model": "fal-ai/flux-general",
      "controlnet_canny": "InstantX/FLUX.1-dev-Controlnet-Canny",
      "controlnet_depth": "Shakker-Labs/FLUX.1-dev-ControlNet-Depth",
      "canny_strength": 0.8,
      "depth_strength": 0.95,
      "steps": 28,
      "guidance_scale": 3.5,
      "timeout": 120
    },
    "fal_comfy": {
      "_doc": "fal.ai Cloud ComfyUI — serverless ComfyUI workflow execution. Requires FAL_KEY env var. Models downloaded from HuggingFace URLs (cached on fal infra after first run).",
      "endpoint": "fal-ai/comfy",
      "workflow_template": "templates/fal_comfy_workflow_template.json",
      "checkpoint_url": "https://huggingface.co/SG161222/Realistic_Vision_V5.1_noVAE/resolve/main/Realistic_Vision_V5.1_fp16-no-ema.safetensors",
      "controlnet_depth_url": "https://huggingface.co/lllyasviel/ControlNet-v1-1/resolve/main/control_v11f1p_sd15_depth.pth",
      "controlnet_canny_url": "https://huggingface.co/lllyasviel/ControlNet-v1-1/resolve/main/control_v11p_sd15_canny.pth",
      "canny_strength": 0.8,
      "depth_strength": 0.95,
      "denoise_strength": 0.45,
      "cfg_scale": 7.0,
      "steps": 25,
      "timeout": 300
    },
    "engineering": {
      "_doc": "No AI — Blender PBR render → light post-processing → JPG. Perfect geometry, zero cost.",
      "sharpness": 1.3,
      "contrast": 1.1,
      "quality": 95
    }
  }
}
