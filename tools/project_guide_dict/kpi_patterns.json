{
  "schema_version": 2,
  "lifting_platform": {
    "load_kg": {
      "regex": [
        {"pattern": "(\\d+(?:\\.\\d+)?)\\s*(?:kg|公斤|千克)", "factor": 1}
      ],
      "context_terms": ["载荷", "承载", "负载", "升起", "举起", "提升", "升"],
      "unit": "kg",
      "slot": "capability_1"
    },
    "stroke_mm": {
      "regex": [
        {"pattern": "(\\d+(?:\\.\\d+)?)\\s*(?:mm|毫米)", "factor": 1},
        {"pattern": "(\\d+(?:\\.\\d+)?)\\s*(?:cm|厘米)", "factor": 10},
        {"pattern": "(\\d+(?:\\.\\d+)?)\\s*m(?![ms])", "factor": 1000},
        {"pattern": "(\\d+(?:\\.\\d+)?)\\s*米(?!\\s*厘)", "factor": 1000}
      ],
      "context_terms": ["行程", "升高", "升程", "stroke", "travel"],
      "unit": "mm",
      "slot": "capability_2"
    },
    "platform_size_mm": {
      "regex": [
        {"pattern": "(\\d+)\\s*[x×]\\s*(\\d+)\\s*(?:mm|毫米)?", "factor": 1}
      ],
      "context_terms": ["平台", "platform", "尺寸", "外形", "包络", "面积"],
      "unit": "mm",
      "value_shape": "pair",
      "slot": "envelope"
    }
  },
  "end_effector": {
    "rot_range_deg": {
      "regex": [
        {"pattern": "[±]?\\s*(\\d+(?:\\.\\d+)?)\\s*[°度]", "factor": 1}
      ],
      "context_terms": ["翻转", "旋转", "rotation", "rotate"],
      "unit": "deg",
      "slot": "capability_1"
    },
    "switch_time_s": {
      "regex": [
        {"pattern": "(\\d+(?:\\.\\d+)?)\\s*(?:s|秒)", "factor": 1}
      ],
      "context_terms": ["切换", "switch"],
      "unit": "s",
      "slot": "capability_2"
    },
    "flange_dia_mm": {
      "regex": [
        {"pattern": "Φ\\s*(\\d+(?:\\.\\d+)?)", "factor": 1},
        {"pattern": "(\\d+)\\s*mm\\s*法兰", "factor": 1},
        {"pattern": "flange\\s*(\\d+)", "factor": 1}
      ],
      "context_terms": ["法兰", "flange"],
      "unit": "mm",
      "slot": "envelope"
    }
  }
}
